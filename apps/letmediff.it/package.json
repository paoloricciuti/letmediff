{
	"name": "letmediff.it",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test"
	},
	"devDependencies": {
		"@eslint/compat": "catalog:tooling",
		"@eslint/js": "catalog:tooling",
		"@playwright/test": "catalog:tooling",
		"@sveltejs/adapter-vercel": "catalog:svelte",
		"@sveltejs/kit": "catalog:svelte",
		"@sveltejs/vite-plugin-svelte": "catalog:svelte",
		"@types/node": "catalog:tooling",
		"@vitest/browser-playwright": "catalog:vitest",
		"eslint": "catalog:tooling",
		"eslint-config-prettier": "catalog:tooling",
		"eslint-plugin-svelte": "catalog:tooling",
		"globals": "catalog:tooling",
		"playwright": "catalog:tooling",
		"prettier": "catalog:tooling",
		"prettier-plugin-svelte": "catalog:tooling",
		"svelte": "catalog:svelte",
		"svelte-check": "catalog:svelte",
		"typescript": "catalog:tooling",
		"typescript-eslint": "catalog:tooling",
		"vite": "catalog:tooling",
		"vitest": "catalog:vitest",
		"vitest-browser-svelte": "catalog:vitest"
	},
	"dependencies": {
		"@fontsource/geist-mono": "catalog:fonts",
		"@fontsource/geist-sans": "catalog:fonts",
		"@neoconfetti/svelte": "catalog:deps",
		"@pierre/diffs": "catalog:deps",
		"@umami/node": "catalog:analytics",
		"@upstash/redis": "catalog:deps",
		"unstorage": "catalog:deps",
		"valibot": "catalog:validation"
	}
}
