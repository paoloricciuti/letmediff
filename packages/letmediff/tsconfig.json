{
	"compilerOptions": {
		"module": "nodenext",
		"target": "esnext",
		"lib": ["ESNext"],
		"types": ["node"],
		"noEmit": true,
		"sourceMap": false,
		"declaration": false,
		"declarationMap": false,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"strict": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"noUncheckedSideEffectImports": true,
		"moduleDetection": "force",
		"skipLibCheck": true,
		"checkJs": true,
		"allowJs": true
	},
	"include": ["./src", "scripts"]
}
