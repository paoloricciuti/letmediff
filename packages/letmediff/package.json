{
	"name": "letmediff",
	"version": "0.0.9",
	"publishConfig": {
		"access": "public"
	},
	"mcpName": "it.letmediff/mcp",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/paoloricciuti/letmediff.git",
		"path": "packages/letmediff"
	},
	"description": "MCP server of letmediff.it...allows the agent to show the diff url and receive the diff comments from the server",
	"main": "src/index.js",
